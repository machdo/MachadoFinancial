generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int           @id @default(autoincrement())
  name         String
  email        String        @unique
  password     String
  accounts     Account[]
  categories   Category[]
  transactions Transaction[]
  goals        Goal[]
  categoryBudgets CategoryBudget[]
  annualBudgets AnnualBudget[]
  accountLimits AccountLimit[]
  creditCards  CreditCard[]
  creditCardInvoices CreditCardInvoice[]
  createdAt    DateTime      @default(now())
}

model Account {
  id           Int           @id @default(autoincrement())
  name         String
  type         String
  balance      Float         @default(0)
  userId       Int
  user         User          @relation(fields: [userId], references: [id])
  transactions Transaction[]
  accountLimits AccountLimit[]
}

model Category {
  id           Int           @id @default(autoincrement())
  name         String
  color        String
  type         String        @default("expense")
  userId       Int
  user         User          @relation(fields: [userId], references: [id])
  transactions Transaction[]
  categoryBudgets CategoryBudget[]
}

model Transaction {
  id          Int      @id @default(autoincrement())
  type        String
  value       Float
  description String?
  date        DateTime
  userId      Int
  accountId   Int
  categoryId  Int
  user        User     @relation(fields: [userId], references: [id])
  account     Account  @relation(fields: [accountId], references: [id])
  category    Category @relation(fields: [categoryId], references: [id])
}

model Goal {
  id           Int      @id @default(autoincrement())
  name         String
  targetValue  Float
  currentValue Float    @default(0)
  deadline     DateTime
  userId       Int
  user         User     @relation(fields: [userId], references: [id])
}

model CategoryBudget {
  id          Int      @id @default(autoincrement())
  userId      Int
  categoryId  Int
  year        Int
  month       Int
  amount      Float
  alertPercent Int     @default(80)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id])
  category    Category @relation(fields: [categoryId], references: [id])

  @@unique([userId, categoryId, year, month])
}

model AnnualBudget {
  id           Int      @id @default(autoincrement())
  userId       Int
  year         Int
  amount       Float
  alertPercent Int      @default(80)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id])

  @@unique([userId, year])
}

model AccountLimit {
  id           Int      @id @default(autoincrement())
  userId       Int
  accountId    Int
  monthlyLimit Float
  alertPercent Int      @default(80)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id])
  account      Account  @relation(fields: [accountId], references: [id])

  @@unique([userId, accountId])
}

model CreditCard {
  id               Int      @id @default(autoincrement())
  name             String
  totalLimit       Float
  bestPurchaseDay  Int
  closingDay       Int
  autoInstallments Boolean  @default(true)
  userId           Int
  user             User     @relation(fields: [userId], references: [id])
  invoices         CreditCardInvoice[]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model CreditCardInvoice {
  id           Int        @id @default(autoincrement())
  userId       Int
  creditCardId Int
  year         Int
  month        Int
  closingDate  DateTime?
  totalAmount  Float      @default(0)
  paidAmount   Float      @default(0)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  user         User       @relation(fields: [userId], references: [id])
  creditCard   CreditCard @relation(fields: [creditCardId], references: [id])

  @@unique([userId, creditCardId, year, month])
}
